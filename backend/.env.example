PORT=3000
DB_PATH=unoporciento.sqlite
JWT_SECRET=cambiar-este-secreto-en-produccion
FRONTEND_URL=http://localhost:4200

# Instagram Graph API (opcional): sin estas variables el feed de la
# landing simplemente no muestra publicaciones. Requiere una cuenta
# de Instagram Business/Creator vinculada a una página de Facebook y
# un token de larga duración generado desde Meta for Developers.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
